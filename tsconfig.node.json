{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.unit.config.ts",
    "vitest.worker.config.ts",
    "playwright.config.ts",
    "e2e"
  ]
}
